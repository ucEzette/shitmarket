# ─── Solana (Mainnet-Beta) ───────────────────────────────────────────
SOLANA_RPC_URL=https://api.mainnet-beta.solana.com
# Secondary RPC for automatic failover (optional, recommended for production)
SOLANA_SECONDARY_RPC_URL=https://solana-mainnet.g.alchemy.com/v2/your-key
SOLANA_WS_URL=wss://api.mainnet-beta.solana.com
PROGRAM_ID=GxkRWMoyKpKkTadmGqqqLvA473YTwvDUeSPK1iS8REim

# Keeper wallet — base58-encoded private key (64 bytes)
# Generate: solana-keygen new --outfile keeper.json && cat keeper.json
KEEPER_PRIVATE_KEY=[1,2,3,...,64]

# ─── Database ─────────────────────────────────────────────────────────
# Production Postgres connection (e.g., Supabase, Railway, Neon)
DATABASE_URL=postgresql://shitmarket:shitmarket@localhost:5432/shitmarket_mainnet

# ─── Redis ───────────────────────────────────────────────────────────
# Production Redis (e.g., Upstash, Redis Cloud)
REDIS_URL=redis://localhost:6379

# ─── Pyth Feed Mapping ───────────────────────────────────────────────────────
# JSON string: { "tokenMint": "pythFeedPubkey" }
# Used for tokens that DO have a Pyth feed (optional — keeper uses off-chain TWAP)
PYTH_FEED_MAPPING={}

# ─── Switchboard Feed Mapping (Phase 3.1) ──────────────────────────────────
# JSON string: { "tokenMint": "switchboardFeedPubkey" }
SWITCHBOARD_FEED_MAPPING='{}'

MINIMUM_MARKET_CAP=50000
MINIMUM_TOKEN_AGE_MINUTES=30

# ─── API Servers ─────────────────────────────────────────────────────────────
REST_API_PORT=3001
WS_PORT=3002

# ─── External APIs (for price aggregation) ───────────────────────────────────
DEXSCREENER_API_URL=https://api.dexscreener.com/latest/dex
BIRDEYE_API_KEY=your_birdeye_api_key_here
PYTH_REST_URL=https://hermes.pyth.network
# Jupiter price API for additional price source
JUPITER_PRICE_API_URL=https://api.jup.ag/price/v2

# ─── Logging ─────────────────────────────────────────────────────────────────
LOG_LEVEL=info
NODE_ENV=development
