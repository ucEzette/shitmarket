{
  "name": "shitmarket-indexer",
  "version": "1.0.0",
  "description": "ShitMarket — Solana event indexer, settlement keeper, WebSocket server, and REST API",
  "main": "dist/index.js",
  "scripts": {
    "build": "esbuild src/*.ts src/*/*.ts src/*/*/*.ts --outdir=dist --platform=node --target=node20 --format=cjs",
    "dev": "ts-node-dev --respawn --transpile-only src/index.ts",
    "start": "node dist/index.js",
    "db:generate": "prisma generate",
    "db:migrate": "prisma migrate deploy",
    "db:studio": "prisma studio",
    "test": "jest --runInBand --forceExit",
    "lint": "eslint 'src/**/*.ts'"
  },
  "dependencies": {
    "@coral-xyz/anchor": "^0.30.1",
    "@prisma/client": "^5.14.0",
    "@solana/web3.js": "^1.91.7",
    "axios": "^1.16.1",
    "bs58": "^5.0.0",
    "cors": "^2.8.5",
    "dotenv": "^16.4.5",
    "express": "^4.19.2",
    "express-rate-limit": "^7.3.1",
    "helmet": "^7.1.0",
    "ioredis": "^5.3.2",
    "node-cron": "^3.0.3",
    "pino": "^9.2.0",
    "pino-pretty": "^11.2.0",
    "prom-client": "^15.1.3",
    "tweetnacl": "^1.0.3",
    "viem": "^2.55.4",
    "ws": "^8.17.0",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@types/cors": "^2.8.17",
    "@types/express": "^4.17.21",
    "@types/jest": "^29.5.12",
    "@types/node": "^20.14.2",
    "@types/node-cron": "^3.0.11",
    "@types/ws": "^8.5.10",
    "esbuild": "^0.28.1",
    "jest": "^29.7.0",
    "prisma": "^5.14.0",
    "ts-jest": "^29.1.4",
    "ts-node": "^10.9.2",
    "ts-node-dev": "^2.0.0",
    "typescript": "^5.5.4"
  },
  "overrides": {
    "uuid": "^8.3.2"
  },
  "jest": {
    "preset": "ts-jest",
    "testEnvironment": "node",
    "testMatch": [
      "**/tests/**/*.test.ts"
    ],
    "testTimeout": 120000
  }
}
