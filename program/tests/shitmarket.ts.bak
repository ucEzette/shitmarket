import * as anchor from "@coral-xyz/anchor";
import { BN, AnchorError } from "@coral-xyz/anchor";

import {
  Keypair,
  LAMPORTS_PER_SOL,
  PublicKey,
  SystemProgram,
} from "@solana/web3.js";
import { assert, expect } from "chai";
// Note: Shitmarket type is generated by `anchor build` into target/types/shitmarket.json
// Until the first build runs we define a minimal alias so TypeScript is happy.
type Shitmarket = any; // replaced with `import { Shitmarket } from "../target/types/shitmarket"` after `anchor build`


// ─────────────────────────────────────────────
//  Helpers
// ─────────────────────────────────────────────

async function airdrop(
  provider: anchor.AnchorProvider,
  pubkey: PublicKey,
  sol: number
) {
  const sig = await provider.connection.requestAirdrop(
    pubkey,
    sol * LAMPORTS_PER_SOL
  );
  await provider.connection.confirmTransaction(sig, "confirmed");
}

function deriveConfig(programId: PublicKey): [PublicKey, number] {
  return PublicKey.findProgramAddressSync(
    [Buffer.from("platform_config")],
    programId
  );
}

function deriveRoom(
  tokenMint: PublicKey,
  creator: PublicKey,
  programId: PublicKey
): [PublicKey, number] {
  return PublicKey.findProgramAddressSync(
    [Buffer.from("room"), tokenMint.toBuffer(), creator.toBuffer()],
    programId
  );
}

function deriveBet(
  room: PublicKey,
  user: PublicKey,
  programId: PublicKey
): [PublicKey, number] {
  return PublicKey.findProgramAddressSync(
    [Buffer.from("bet"), room.toBuffer(), user.toBuffer()],
    programId
  );
}

function deriveEscrow(room: PublicKey, programId: PublicKey): [PublicKey, number] {
  return PublicKey.findProgramAddressSync(
    [Buffer.from("escrow"), room.toBuffer()],
    programId
  );
}

// Mock token mint — we only store its pubkey on-chain, no real SPL mint needed
const MOCK_TOKEN_MINT = Keypair.generate().publicKey;
const MOCK_TOKEN_NAME = "PEPE5";
const MOCK_PRICE_FEED = Keypair.generate();
const MOCK_OPENING_PRICE = new BN(1_000_000); // $1.00 (×1_000_000)

async function createFakePythFeedAccount(provider: anchor.AnchorProvider, feedKeypair: Keypair) {
  const lamports = await provider.connection.getMinimumBalanceForRentExemption(2048);
  const tx = new anchor.web3.Transaction().add(
    SystemProgram.createAccount({
      fromPubkey: provider.wallet.publicKey,
      newAccountPubkey: feedKeypair.publicKey,
      lamports,
      space: 2048,
      programId: new PublicKey("Pyth11111111111111111111111111111111111111"),
    })
  );
  await provider.sendAndConfirm(tx, [feedKeypair]);
}

// ─────────────────────────────────────────────
//  Test Suite
// ─────────────────────────────────────────────

describe("shitmarket", () => {
  const provider = anchor.AnchorProvider.env();
  anchor.setProvider(provider);

  // eslint-disable-next-line @typescript-eslint/no-explicit-any
  const program = anchor.workspace.Shitmarket as any; // typed as any until `anchor build` generates ../target/types/shitmarket
  const programId: PublicKey = (program as { programId: PublicKey }).programId;


  // Wallets
  const admin = Keypair.generate();
  const treasury = Keypair.generate();
  const keeper = Keypair.generate();
  const creator = Keypair.generate();
  const moonBettor = Keypair.generate();
  const jeetBettor = Keypair.generate();
  const secondMoonBettor = Keypair.generate();

  // PDAs (populated in tests)
  let configPda: PublicKey;
  let roomPda: PublicKey;
  let escrowPda: PublicKey;
  let moonBetPda: PublicKey;
  let jeetBetPda: PublicKey;
  let secondMoonBetPda: PublicKey;

  before(async () => {
    // Fund all wallets
    await Promise.all([
      airdrop(provider, admin.publicKey, 10),
      airdrop(provider, treasury.publicKey, 1),
      airdrop(provider, creator.publicKey, 5),
      airdrop(provider, moonBettor.publicKey, 5),
      airdrop(provider, jeetBettor.publicKey, 5),
      airdrop(provider, secondMoonBettor.publicKey, 5),
    ]);

    await createFakePythFeedAccount(provider, MOCK_PRICE_FEED);

    [configPda] = deriveConfig(programId);
    [roomPda] = deriveRoom(MOCK_TOKEN_MINT, creator.publicKey, programId);
    [escrowPda] = deriveEscrow(roomPda, programId);
    [moonBetPda] = deriveBet(roomPda, moonBettor.publicKey, programId);
    [jeetBetPda] = deriveBet(roomPda, jeetBettor.publicKey, programId);
    [secondMoonBetPda] = deriveBet(roomPda, secondMoonBettor.publicKey, programId);
  });

  // ── 1. Initialize ─────────────────────────────────────────────────────

  it("initializes platform config with 2% fee", async () => {
    await program.methods
      .initialize(200) // 200 bps = 2%
      .accounts({
        config: configPda,
        admin: admin.publicKey,
        treasury: treasury.publicKey,
        systemProgram: SystemProgram.programId,
      })
      .signers([admin])
      .rpc();

    const config = await program.account.platformConfig.fetch(configPda);
    assert.equal(config.admin.toBase58(), admin.publicKey.toBase58());
    assert.equal(config.treasury.toBase58(), treasury.publicKey.toBase58());
    assert.equal(config.platformFeeBps, 200);
  });

  it("rejects fee > 10%", async () => {
    try {
      await program.methods
        .initialize(1001)
        .accounts({
          config: configPda,
          admin: admin.publicKey,
          treasury: treasury.publicKey,
          systemProgram: SystemProgram.programId,
        })
        .signers([admin])
        .rpc();
      assert.fail("Should have thrown");
    } catch (err: any) {
      expect(err.message).to.include("FeeTooHigh");
    }
  });

  // ── 2. Create Room ────────────────────────────────────────────────────

  it("creates a room with 5-minute duration", async () => {
    await program.methods
      .createRoom(
        MOCK_TOKEN_MINT,
        MOCK_TOKEN_NAME,
        5 // 5 minutes
      )
      .accounts({
        room: roomPda,
        escrow: escrowPda,
        creator: creator.publicKey,
        priceFeed: MOCK_PRICE_FEED.publicKey,
        config: configPda,
        systemProgram: SystemProgram.programId,
      })
      .signers([creator])
      .rpc();

    const room = await program.account.room.fetch(roomPda);
    assert.equal(room.tokenMint.toBase58(), MOCK_TOKEN_MINT.toBase58());
    assert.equal(room.durationMinutes, 5);
    assert.isTrue(room.openingPrice.eq(MOCK_OPENING_PRICE));
    assert.equal(room.moonPool.toNumber(), 0);
    assert.equal(room.jeetPool.toNumber(), 0);
    assert.deepEqual(room.status, { active: {} });
    assert.isNull(room.winner);
  });

  it("rejects invalid durations", async () => {
    const otherMint = Keypair.generate().publicKey;
    const [otherRoom] = deriveRoom(otherMint, creator.publicKey, programId);
    try {
      await program.methods
        .createRoom(otherMint, "BAD", 7)
        .accounts({
          room: otherRoom,
          escrow: deriveEscrow(otherRoom, programId)[0],
          creator: creator.publicKey,
          priceFeed: MOCK_PRICE_FEED.publicKey,
          config: configPda,
          systemProgram: SystemProgram.programId,
        })
        .signers([creator])
        .rpc();
      assert.fail("Should have thrown");
    } catch (err: any) {
      expect(err.message).to.include("InvalidDuration");
    }
  });

  // ── 3. Place Bets ─────────────────────────────────────────────────────

  it("places a bet on Moon side (1 SOL)", async () => {
    const betAmount = new BN(1 * LAMPORTS_PER_SOL);

    await program.methods
      .placeBet({ moon: {} }, betAmount)
      .accounts({
        room: roomPda,
        escrow: escrowPda,
        bet: moonBetPda,
        user: moonBettor.publicKey,
        systemProgram: SystemProgram.programId,
      })
      .signers([moonBettor])
      .rpc();

    const room = await program.account.room.fetch(roomPda);
    assert.isTrue(room.moonPool.eq(betAmount));
    assert.isTrue(room.jeetPool.eq(new BN(0)));

    const bet = await program.account.bet.fetch(moonBetPda);
    assert.isTrue(bet.amount.eq(betAmount));
    assert.deepEqual(bet.side, { moon: {} });
    assert.isFalse(bet.claimed);
  });

  it("places a bet on Jeet side (0.5 SOL)", async () => {
    const betAmount = new BN(0.5 * LAMPORTS_PER_SOL);

    await program.methods
      .placeBet({ jeet: {} }, betAmount)
      .accounts({
        room: roomPda,
        escrow: escrowPda,
        bet: jeetBetPda,
        user: jeetBettor.publicKey,
        systemProgram: SystemProgram.programId,
      })
      .signers([jeetBettor])
      .rpc();

    const room = await program.account.room.fetch(roomPda);
    assert.isTrue(room.jeetPool.eq(betAmount));
  });

  it("adds to an existing Moon bet (another 0.5 SOL)", async () => {
    const extraAmount = new BN(0.5 * LAMPORTS_PER_SOL);

    await program.methods
      .placeBet({ moon: {} }, extraAmount)
      .accounts({
        room: roomPda,
        escrow: escrowPda,
        bet: moonBetPda,
        user: moonBettor.publicKey,
        systemProgram: SystemProgram.programId,
      })
      .signers([moonBettor])
      .rpc();

    const bet = await program.account.bet.fetch(moonBetPda);
    // 1 SOL + 0.5 SOL = 1.5 SOL
    assert.isTrue(bet.amount.eq(new BN(1.5 * LAMPORTS_PER_SOL)));
  });

  it("places a second Moon bettor (0.5 SOL)", async () => {
    const betAmount = new BN(0.5 * LAMPORTS_PER_SOL);
    await program.methods
      .placeBet({ moon: {} }, betAmount)
      .accounts({
        room: roomPda,
        escrow: escrowPda,
        bet: secondMoonBetPda,
        user: secondMoonBettor.publicKey,
        systemProgram: SystemProgram.programId,
      })
      .signers([secondMoonBettor])
      .rpc();

    const room = await program.account.room.fetch(roomPda);
    // 1.5 + 0.5 = 2 SOL moon pool
    assert.isTrue(room.moonPool.eq(new BN(2 * LAMPORTS_PER_SOL)));
  });

  it("rejects zero-amount bets", async () => {
    try {
      await program.methods
        .placeBet({ moon: {} }, new BN(0))
        .accounts({
          room: roomPda,
          escrow: escrowPda,
          bet: moonBetPda,
          user: moonBettor.publicKey,
          systemProgram: SystemProgram.programId,
        })
        .signers([moonBettor])
        .rpc();
      assert.fail("Should have thrown");
    } catch (err: any) {
      expect(err.message).to.include("ZeroBetAmount");
    }
  });

  // ── 4. Settle Room ────────────────────────────────────────────────────
  // Note: because we can't easily warp time in anchor test without a
  // custom validator, we use a very short duration room. For testing
  // settlement on the existing room, we sleep past expiry.

  it("rejects settlement before expiry", async () => {
    const higherPrice = MOCK_OPENING_PRICE.addn(5_000);
    try {
      await program.methods
        .settleRoom()
        .accounts({
          room: roomPda,
          escrow: escrowPda,
          treasury: treasury.publicKey,
          priceFeed: MOCK_PRICE_FEED.publicKey,
          config: configPda,
          systemProgram: SystemProgram.programId,
        })
        .rpc();
      assert.fail("Should have thrown — room not expired");
    } catch (err: any) {
      expect(err.message).to.include("RoomNotExpired");
    }
  });

  it("settles room after expiry with Moon winning price", async () => {
    // Wait for 5-minute room to expire (300s). In real tests use fast-forward;
    // here we wait just enough for localnet (set room to 5s for this test).
    // For the purpose of this suite we'll create a separate "fast" room below.
    // The 5-minute room tests above are valid structural tests; settlement is
    // tested with a fast-expiry room in the next block.
    console.log("  Skipping live expiry wait for 5min room — see fast-room tests below.");
  });

  // ── 4b. Fast-Expiry Room for Settlement Tests ─────────────────────────

  describe("fast-expiry settlement flow", () => {
    const fastMint = Keypair.generate().publicKey;
    const fastCreator = Keypair.generate();
    let fastRoomPda: PublicKey;
    let fastEscrowPda: PublicKey;
    let fastMoonBetPda: PublicKey;
    let fastJeetBetPda: PublicKey;
    const fastMoonBettor = Keypair.generate();
    const fastJeetBettor = Keypair.generate();

    before(async () => {
      await Promise.all([
        airdrop(provider, fastCreator.publicKey, 3),
        airdrop(provider, fastMoonBettor.publicKey, 3),
        airdrop(provider, fastJeetBettor.publicKey, 3),
      ]);

      [fastRoomPda] = deriveRoom(fastMint, fastCreator.publicKey, programId);
      [fastEscrowPda] = deriveEscrow(fastRoomPda, programId);
      [fastMoonBetPda] = deriveBet(fastRoomPda, fastMoonBettor.publicKey, programId);
      [fastJeetBetPda] = deriveBet(fastRoomPda, fastJeetBettor.publicKey, programId);
    });

    it("creates a fast room (5-min — expires quickly in localnet warp)", async () => {
      // On localnet, 5-minute rooms expire in 5 minutes real time. We create
      // the room and assume test validator slot-time allows us to proceed.
      // In CI, use `--skip-preflight` + localnet time warp via `anchor test`.
      await program.methods
        .createRoom(fastMint, "FASTTOKEN", 5, new BN(1_000_000))
        .accounts({
          room: fastRoomPda,
          creator: fastCreator.publicKey,
          config: configPda,
          systemProgram: SystemProgram.programId,
        })
        .signers([fastCreator])
        .rpc();
    });

    it("places bets on both sides of fast room", async () => {
      // Moon: 1 SOL
      await program.methods
        .placeBet({ moon: {} }, new BN(LAMPORTS_PER_SOL))
        .accounts({
          room: fastRoomPda,
          escrow: fastEscrowPda,
          bet: fastMoonBetPda,
          user: fastMoonBettor.publicKey,
          systemProgram: SystemProgram.programId,
        })
        .signers([fastMoonBettor])
        .rpc();

      // Jeet: 0.5 SOL
      await program.methods
        .placeBet({ jeet: {} }, new BN(0.5 * LAMPORTS_PER_SOL))
        .accounts({
          room: fastRoomPda,
          escrow: fastEscrowPda,
          bet: fastJeetBetPda,
          user: fastJeetBettor.publicKey,
          systemProgram: SystemProgram.programId,
        })
        .signers([fastJeetBettor])
        .rpc();

      const room = await program.account.room.fetch(fastRoomPda);
      assert.isTrue(room.moonPool.eq(new BN(LAMPORTS_PER_SOL)));
      assert.isTrue(room.jeetPool.eq(new BN(0.5 * LAMPORTS_PER_SOL)));
    });

    // NOTE: The following tests require the room to be expired.
    // Run with `anchor test -- --timeout 400000` and the localnet
    // must have fast slot times, OR warp clock using test-validator flags.
    // For CI, use: solana-test-validator --limit-ledger-size 50000000 &
    // and set BPF_LOADER_UPGRADEABLE=1

    it("(TIME-DEPENDENT) settles room after expiry — Moon wins", async function () {
      this.timeout(400_000);
      const fastRoom = await program.account.room.fetch(fastRoomPda);
      const now = Math.floor(Date.now() / 1000);
      const waitMs = (fastRoom.expiryTimestamp.toNumber() - now + 2) * 1000;

      if (waitMs > 0) {
        console.log(`  Waiting ${Math.ceil(waitMs / 1000)}s for room to expire...`);
        await new Promise((r) => setTimeout(r, waitMs));
      }

      const finalPrice = new BN(2_000_000); // $2.00 > $1.00 opening → Moon wins
      const treasuryBefore = await provider.connection.getBalance(treasury.publicKey);

      await program.methods
        .settleRoom()
        .accounts({
          room: fastRoomPda,
          escrow: fastEscrowPda,
          treasury: treasury.publicKey,
          priceFeed: MOCK_PRICE_FEED.publicKey,
          config: configPda,
          systemProgram: SystemProgram.programId,
        })
        .rpc();

      const room = await program.account.room.fetch(fastRoomPda);
      assert.deepEqual(room.status, { settled: {} });
      assert.deepEqual(room.winner, { moon: {} });
      assert.isTrue(room.finalPrice.eq(finalPrice));

      // Verify platform fee arrived at treasury
      // Total pool = 1.5 SOL; fee = 2% = 0.03 SOL = 30_000_000 lamports
      const treasuryAfter = await provider.connection.getBalance(treasury.publicKey);
      const feeReceived = treasuryAfter - treasuryBefore;
      assert.isAtLeast(feeReceived, 29_000_000, "Treasury should receive ~2% fee");
    });

    it("(TIME-DEPENDENT) winning Moon bettor claims proportional winnings", async function () {
      this.timeout(30_000);

      const userBefore = await provider.connection.getBalance(fastMoonBettor.publicKey);
      const escrowBefore = await provider.connection.getBalance(fastEscrowPda);
      console.log(`  Escrow balance before claim: ${escrowBefore / LAMPORTS_PER_SOL} SOL`);

      await program.methods
        .claimWinnings()
        .accounts({
          room: fastRoomPda,
          escrow: fastEscrowPda,
          bet: fastMoonBetPda,
          user: fastMoonBettor.publicKey,
          systemProgram: SystemProgram.programId,
        })
        .signers([fastMoonBettor])
        .rpc();

      const userAfter = await provider.connection.getBalance(fastMoonBettor.publicKey);
      const gain = userAfter - userBefore;
      console.log(`  Moon bettor gained: ${gain / LAMPORTS_PER_SOL} SOL`);
      assert.isAbove(gain, 0, "Winner should receive lamports");

      const bet = await program.account.bet.fetch(fastMoonBetPda);
      assert.isTrue(bet.claimed, "Bet should be marked claimed");
    });

    it("rejects double-claim", async function () {
      try {
        await program.methods
          .claimWinnings()
          .accounts({
            room: fastRoomPda,
            escrow: fastEscrowPda,
            bet: fastMoonBetPda,
            user: fastMoonBettor.publicKey,
            systemProgram: SystemProgram.programId,
          })
          .signers([fastMoonBettor])
          .rpc();
        assert.fail("Should have thrown");
      } catch (err: any) {
        expect(err.message).to.include("AlreadyClaimed");
      }
    });

    it("Jeet bettor cannot claim on Moon-winning room", async function () {
      try {
        await program.methods
          .claimWinnings()
          .accounts({
            room: fastRoomPda,
            escrow: fastEscrowPda,
            bet: fastJeetBetPda,
            user: fastJeetBettor.publicKey,
            systemProgram: SystemProgram.programId,
          })
          .signers([fastJeetBettor])
          .rpc();
        assert.fail("Should have thrown");
      } catch (err: any) {
        expect(err.message).to.include("NotAWinner");
      }
    });

    it("rejects double settlement", async function () {
      try {
        await program.methods
          .settleRoom()
          .accounts({
            room: fastRoomPda,
            escrow: fastEscrowPda,
            treasury: treasury.publicKey,
            priceFeed: MOCK_PRICE_FEED.publicKey,
            config: configPda,
            systemProgram: SystemProgram.programId,
          })
          .rpc();
        assert.fail("Should have thrown");
      } catch (err: any) {
        expect(err.message).to.include("RoomAlreadySettled");
      }
    });
  });

  // ── 5. Update Config ─────────────────────────────────────────────────

  it("admin updates fee to 1%", async () => {
    await program.methods
      .updateConfig(100, null) // 100 bps = 1%
      .accounts({
        config: configPda,
        admin: admin.publicKey,
        newTreasury: null,
      })
      .signers([admin])
      .rpc();

    const config = await program.account.platformConfig.fetch(configPda);
    assert.equal(config.platformFeeBps, 100);
  });

  it("non-admin cannot update config", async () => {
    try {
      await program.methods
        .updateConfig(50, null)
        .accounts({
          config: configPda,
          admin: creator.publicKey,
          newTreasury: null,
        })
        .signers([creator])
        .rpc();
      assert.fail("Should have thrown");
    } catch (err: any) {
      expect(err.message).to.include("Unauthorized");
    }
  });

  // ── 6. Edge Cases ─────────────────────────────────────────────────────

  describe("edge cases", () => {
    const edgeMint = Keypair.generate().publicKey;
    const edgeCreator = Keypair.generate();
    const lonelyBettor = Keypair.generate();
    let edgeRoomPda: PublicKey;
    let edgeEscrowPda: PublicKey;
    let lonelyBetPda: PublicKey;

    before(async () => {
      await Promise.all([
        airdrop(provider, edgeCreator.publicKey, 3),
        airdrop(provider, lonelyBettor.publicKey, 3),
      ]);
      [edgeRoomPda] = deriveRoom(edgeMint, edgeCreator.publicKey, programId);
      [edgeEscrowPda] = deriveEscrow(edgeRoomPda, programId);
      [lonelyBetPda] = deriveBet(edgeRoomPda, lonelyBettor.publicKey, programId);
    });

    it("room with bets only on one side settles correctly", async function () {
      this.timeout(400_000);

      await program.methods
        .createRoom(edgeMint, "LONELY", 5)
        .accounts({
          room: edgeRoomPda,
          escrow: edgeEscrowPda,
          creator: edgeCreator.publicKey,
          priceFeed: MOCK_PRICE_FEED.publicKey,
          config: configPda,
          systemProgram: SystemProgram.programId,
        })
        .signers([edgeCreator])
        .rpc();

      // Only one bettor on Moon side
      await program.methods
        .placeBet({ moon: {} }, new BN(LAMPORTS_PER_SOL))
        .accounts({
          room: edgeRoomPda,
          escrow: edgeEscrowPda,
          bet: lonelyBetPda,
          user: lonelyBettor.publicKey,
          systemProgram: SystemProgram.programId,
        })
        .signers([lonelyBettor])
        .rpc();

      // Wait for expiry
      const edgeRoom = await program.account.room.fetch(edgeRoomPda);
      const now = Math.floor(Date.now() / 1000);
      const waitMs = (edgeRoom.expiryTimestamp.toNumber() - now + 2) * 1000;
      if (waitMs > 0) {
        console.log(`  Waiting ${Math.ceil(waitMs / 1000)}s...`);
        await new Promise((r) => setTimeout(r, waitMs));
      }

      // Moon wins (price went up)
      await program.methods
        .settleRoom()
        .accounts({
          room: edgeRoomPda,
          escrow: edgeEscrowPda,
          treasury: treasury.publicKey,
          priceFeed: MOCK_PRICE_FEED.publicKey,
          config: configPda,
          systemProgram: SystemProgram.programId,
        })
        .rpc();

      const settled = await program.account.room.fetch(edgeRoomPda);
      assert.deepEqual(settled.winner, { moon: {} });

      // Lonely bettor claims — gets full pot minus fee
      await program.methods
        .claimWinnings()
        .accounts({
          room: edgeRoomPda,
          escrow: edgeEscrowPda,
          bet: lonelyBetPda,
          user: lonelyBettor.publicKey,
          systemProgram: SystemProgram.programId,
        })
        .signers([lonelyBettor])
        .rpc();

      const bet = await program.account.bet.fetch(lonelyBetPda);
      assert.isTrue(bet.claimed);
      console.log("  Lonely winner claimed successfully — full pot minus fee.");
    });
  });
});
