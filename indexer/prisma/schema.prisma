// This is your Prisma schema file

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

// ─── Rooms ────────────────────────────────────────────────────────────────────

model Room {
  id              String   @id @default(uuid()) @db.Uuid
  roomPubkey      String   @unique @map("room_pubkey") @db.VarChar(66)
  tokenMint       String   @map("token_mint") @db.VarChar(66)
  priceFeed       String?  @map("price_feed") @db.VarChar(66)
  switchboardFeed String?  @map("switchboard_feed") @db.VarChar(66)
  tokenName       String?  @map("token_name")
  tokenSymbol     String?  @map("token_symbol")
  tokenImageUrl   String?  @map("token_image_url")
  chainId         String?  @default("solana") @map("chain_id")
  originalAddress String?  @map("original_address")
  duration        Int
  openingPrice    BigInt   @map("opening_price")
  expiry          DateTime @db.Timestamptz()
  status          String   @default("active") @db.VarChar(10)
  winner          String?  @db.VarChar(5)
  finalPrice      BigInt?  @map("final_price")
  twapFinalPrice  BigInt?  @map("twap_final_price")
  totalPool       BigInt   @default(0) @map("total_pool")
  platformFee     BigInt   @default(0) @map("platform_fee")
  creator             String?  @map("creator") @db.VarChar(66)
  createdAt       DateTime @default(now()) @map("created_at") @db.Timestamptz()

  // New fields for Disagreement & Oracle layer
  oracleAddress       String?   @map("oracle_address") @db.VarChar(66)
  oracleFeeLamports   BigInt    @default(0) @map("oracle_fee_lamports")
  settledAt           DateTime? @map("settled_at") @db.Timestamptz()
  disputeStatus       Int       @default(0) @map("dispute_status") // 0 = None, 1 = Overturned
  resolutionCriteria  String?   @map("resolution_criteria") @db.VarChar(100)
  disputedAt          DateTime? @map("disputed_at") @db.Timestamptz()
  disputeChallenger   String?   @map("dispute_challenger") @db.VarChar(66)
  disputeBond         BigInt?   @map("dispute_bond")
  oracleLogs          String?   @map("oracle_logs") @db.Text

  bets            Bet[]
  payouts         Payout[]
  chatMessages    ChatMessage[]

  @@index([status])
  @@index([expiry])
  @@index([createdAt])
  @@index([chainId])
  @@index([totalPool])
  @@map("rooms")
}

// ─── Bets ─────────────────────────────────────────────────────────────────────

model Bet {
  id          String   @id @default(uuid()) @db.Uuid
  roomPubkey  String   @map("room_pubkey") @db.VarChar(66)
  userPubkey  String   @map("user_pubkey") @db.VarChar(66)
  side        String   @db.VarChar(5)
  amount      BigInt
  claimed     Boolean  @default(false)
  txSig       String?  @map("tx_sig") @db.VarChar(88)
  createdAt   DateTime @default(now()) @map("created_at") @db.Timestamptz()

  room        Room     @relation(fields: [roomPubkey], references: [roomPubkey])

  @@index([roomPubkey])
  @@index([userPubkey])
  @@map("bets")
}

// ─── User Profiles ────────────────────────────────────────────────────────────

model UserProfile {
  userPubkey   String   @id @map("user_pubkey") @db.VarChar(66)
  username     String?  @unique @db.VarChar(30)
  avatarUrl    String?  @map("avatar_url")
  referredBy   String?  @map("referred_by") @db.VarChar(66)
  referralCode String?  @unique @map("referral_code") @db.VarChar(20)
  totalBets    Int      @default(0) @map("total_bets")
  wins         Int      @default(0)
  losses       Int      @default(0)
  profit       BigInt   @default(0)
  trenchScore  String   @default("D") @map("trench_score") @db.Char(1)
  achievements Json     @default("[]")
  updatedAt    DateTime @updatedAt @map("updated_at") @db.Timestamptz()

  reputation   Reputation?
  activities   Activity[]

  @@map("user_profiles")
}

// ─── Price Samples for TWAP (Phase 3.2) ────────────────────────────────────

model PriceSample {
  id          String   @id @default(uuid()) @db.Uuid
  tokenMint   String   @map("token_mint") @db.VarChar(44)
  price       BigInt
  source      String   @default("unknown") @db.VarChar(20)
  createdAt   DateTime @default(now()) @map("created_at") @db.Timestamptz()

  @@index([tokenMint, createdAt])
  @@map("price_samples")
}

// ─── Reputation (Phase 3.5) ─────────────────────────────────────────────────

model Reputation {
  id          String   @id @default(uuid()) @db.Uuid
  userPubkey  String   @unique @map("user_pubkey") @db.VarChar(66)
  tier        String   @default("D") @db.Char(1) // D, C, B, A, S
  totalBets   BigInt   @default(0) @map("total_bets")
  totalWins   BigInt   @default(0) @map("total_wins")
  totalVolume BigInt   @default(0) @map("total_volume")
  totalProfit BigInt   @default(0) @map("total_profit")
  lastEval    DateTime @default(now()) @map("last_evaluated") @db.Timestamptz()
  createdAt   DateTime @default(now()) @map("created_at") @db.Timestamptz()

  userProfile UserProfile? @relation(fields: [userPubkey], references: [userPubkey])

  @@map("reputations")
}

// ─── Processed Transactions (idempotency) ────────────────────────────────────

model ProcessedTx {
  signature   String   @id @db.VarChar(88)
  processedAt DateTime @default(now()) @map("processed_at") @db.Timestamptz()

  @@map("processed_txs")
}

// ─── Payouts (computed at settlement) ────────────────────────────────────────

model Payout {
  id          String   @id @default(uuid()) @db.Uuid
  roomPubkey  String   @map("room_pubkey") @db.VarChar(66)
  userPubkey  String   @map("user_pubkey") @db.VarChar(66)
  amount      BigInt
  claimedAt   DateTime? @map("claimed_at") @db.Timestamptz()
  createdAt   DateTime @default(now()) @map("created_at") @db.Timestamptz()

  room        Room     @relation(fields: [roomPubkey], references: [roomPubkey])

  @@unique([roomPubkey, userPubkey])
  @@index([roomPubkey])
  @@index([userPubkey])
  @@map("payouts")
}

// ─── Referral Payouts ────────────────────────────────────────────────────────

model ReferralPayout {
  id           String   @id @default(uuid()) @db.Uuid
  referrer     String   @map("referrer_pubkey") @db.VarChar(66)
  invitee      String   @map("invitee_pubkey") @db.VarChar(66)
  roomPubkey   String   @map("room_pubkey") @db.VarChar(66)
  betAmount    BigInt   @map("bet_amount")
  rewardAmount BigInt   @map("reward_amount")
  txSig        String?  @map("tx_sig") @db.VarChar(88)
  createdAt    DateTime @default(now()) @map("created_at") @db.Timestamptz()

  @@index([referrer])
  @@map("referral_payouts")
}

// ─── WebSocket Chat Messages (Radio Bandwidth) ──────────────────────────

model ChatMessage {
  id         String   @id @default(uuid()) @db.Uuid
  roomPubkey String   @map("room_pubkey") @db.VarChar(66)
  side       String   @db.VarChar(10) // 'moon', 'jeet', or 'all'
  user       String   @db.VarChar(66)
  message    String   @db.VarChar(500)
  timestamp  DateTime @default(now()) @map("timestamp") @db.Timestamptz()

  room       Room     @relation(fields: [roomPubkey], references: [roomPubkey])

  @@index([roomPubkey, timestamp])
  @@map("chat_messages")
}

// ─── Activity Log (Notifications) ──────────────────────────────────────────

model Activity {
  id         String   @id @default(uuid()) @db.Uuid
  userPubkey String   @map("user_pubkey") @db.VarChar(66)
  type       String   @db.VarChar(20)
  title      String   @db.VarChar(100)
  message    String   @db.VarChar(500)
  link       String?  @db.VarChar(200)
  read       Boolean  @default(false)
  createdAt  DateTime @default(now()) @map("created_at") @db.Timestamptz()

  user       UserProfile @relation(fields: [userPubkey], references: [userPubkey])

  @@index([userPubkey, createdAt])
  @@map("activities")
}
